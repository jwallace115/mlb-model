# Streamlit Cloud secrets — paste these into the Streamlit Cloud dashboard
# under App Settings → Secrets. Do NOT commit secrets.toml itself.
#
# For this dashboard (which reads a pre-built results.json),
# no secrets are required at deploy time.
#
# The ODDS_API_KEY is only needed when running the model locally.
# Set it in your local .env file instead.

# ODDS_API_KEY = "your_odds_api_key_here"
